# ============================================================
# Personality Escape Station Environment
# ============================================================
# The H5 quiz and fixed room browsing can run without model keys.
# Model keys are only required when generating reusable personality assets.
# ============================================================

# --- Asset Planner / 资产规划 ---
# OpenAI-compatible chat/completions endpoint.
ORCHESTRATOR_BASE_URL=
ORCHESTRATOR_API_KEY=
ORCHESTRATOR_MODEL=
ORCHESTRATOR_STRUCTURED_OUTPUT_MODE=prompt_only

# --- Image Generation / 地图、主角、Agent、道具生图 ---
# IMAGE_GEN_PROVIDER: openai-compatible or google-native
IMAGE_GEN_PROVIDER=
IMAGE_GEN_BASE_URL=
IMAGE_GEN_API_KEY=
IMAGE_GEN_MODEL=

# Optional player-only override. Use a stricter GPT image model for the 8x8
# walking sheet without changing map, agent, or prop generation.
PLAYER_IMAGE_GEN_PROVIDER=
PLAYER_IMAGE_GEN_BASE_URL=
PLAYER_IMAGE_GEN_API_KEY=
PLAYER_IMAGE_GEN_MODEL=
PLAYER_IMAGE_GEN_TIMEOUT_MS=
PLAYER_IMAGE_GEN_MAX_RETRIES=

# --- Vision Review / 地图与资产审查 ---
VISION_BASE_URL=
VISION_API_KEY=
VISION_MODEL=

# --- Generation Tuning / 生成调参 ---
MAP_ASPECT_RATIO=9:16
MAP_IMAGE_SIZE_K=1
# STEP1_MAX_RETRIES=3
# STEP3_MAX_RETRIES=2
# STEP3_2_MAX_RETRIES=2
# STEP4_MAX_RETRIES=3
